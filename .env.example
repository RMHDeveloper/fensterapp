# Supabase — required for cross-device sync
# Get these from your Supabase project dashboard → Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Hostinger file storage — required for file/photo uploads
# Deploy hostinger/upload.php to your hosting root, then fill in:
VITE_UPLOAD_URL=https://your-domain.com/upload.php
VITE_UPLOAD_KEY=your-upload-secret-key-here

# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — never commit real keys.
